# Local SQLite database placeholder. Production should use Postgres.
DATABASE_URL="file:./dev.db"

# Production database. Use Neon/Supabase/Vercel Postgres connection string.
# POSTGRES_URL takes priority over DATABASE_URL when both exist.
# POSTGRES_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# KASIRKITA_POSTGRES_STATE_KEY="production"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="change-this-secret-minimum-32-characters"
